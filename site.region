<!doctype html>
<html lang="en">
  <head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no">
    <meta name="color-scheme" content="light">
    <meta name="theme-color" content="#1a3d30">
    {squarespace-headers}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400&amp;family=Source+Sans+Pro:ital,wght@0,400;0,500;0,600;0,700;1,400&amp;display=swap" rel="stylesheet">
  </head>
  <body id="{squarespace.page-id}" class="{squarespace.page-classes}">
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="app">
      <header class="app-bar">
        <div class="app-bar__toolbar md-elevation-app-bar">
          {.section website}
            <a class="app-bar__brand" href="/">
              {.if logoImageUrl}
                <img class="app-bar__logo" src="{logoImageUrl}" width="160" height="74" alt="">
              {.end}
              <span class="app-bar__title">{siteTitle}</span>
            </a>
          {.end}
          <button
            type="button"
            class="app-bar__icon-btn"
            aria-expanded="false"
            aria-controls="primary-nav"
            aria-label="Open menu"
          >
            <span class="app-bar__icon-btn-inner" aria-hidden="true">
              <span class="app-bar__menu-line"></span>
              <span class="app-bar__menu-line"></span>
              <span class="app-bar__menu-line"></span>
            </span>
          </button>
          <squarespace:navigation navigationId="siteNav" template="site-navigation" />
        </div>
        <div class="app-bar__scrim" aria-hidden="true"></div>
      </header>

      <main id="main" class="content-container" role="main" data-content-field="main-content">
        {.if homepage}
        <section
          class="screen-hero"
          aria-label="Practice highlights"
          data-carousel
          aria-roledescription="carousel"
        >
          <div class="screen-hero__media">
            <div class="screen-hero__slides">
              <article
                id="carousel-slide-0"
                class="screen-hero__slide screen-hero__slide--lead is-active"
                data-slide="0"
                aria-hidden="false"
              >
                <img
                  class="screen-hero__img"
                  src="/assets/kingsbery-johnson/estate-planning-orbit.jpg"
                  alt=""
                  width="1200"
                  height="800"
                  fetchpriority="high"
                  decoding="async"
                />
                <div class="screen-hero__scrim" aria-hidden="true"></div>
                <div class="screen-hero__content screen-hero__content--lead">
                  <div class="screen-hero__brand-badge">
                    <img
                      class="screen-hero__brand-logo"
                      src="/assets/kingsbery-johnson/KJL-logo.png"
                      width="560"
                      height="258"
                      alt=""
                    />
                    <p class="screen-hero__firm-subhead">
                      {.section website}{siteTitle}{.end}
                    </p>
                  </div>
                  <a class="screen-hero__cta" href="/#practice">
                    <span class="screen-hero__kicker">Practice area</span>
                    <h2 class="screen-hero__title">Estate planning</h2>
                    <span class="screen-hero__arrow" aria-hidden="true">→</span>
                  </a>
                </div>
              </article>
              <article
                id="carousel-slide-1"
                class="screen-hero__slide"
                data-slide="1"
                aria-hidden="true"
              >
                <img
                  class="screen-hero__img"
                  src="/assets/kingsbery-johnson/estate-probate-trust-orbit.jpg"
                  alt=""
                  width="1200"
                  height="800"
                  decoding="async"
                />
                <div class="screen-hero__scrim" aria-hidden="true"></div>
                <div class="screen-hero__content">
                  <a class="screen-hero__cta" href="/#practice">
                    <span class="screen-hero__kicker">Practice area</span>
                    <h2 class="screen-hero__title">Probate &amp; trust administration</h2>
                    <span class="screen-hero__arrow" aria-hidden="true">→</span>
                  </a>
                </div>
              </article>
              <article
                id="carousel-slide-2"
                class="screen-hero__slide"
                data-slide="2"
                aria-hidden="true"
              >
                <img
                  class="screen-hero__img"
                  src="/assets/kingsbery-johnson/business-orbit.jpg"
                  alt=""
                  width="1200"
                  height="800"
                  decoding="async"
                />
                <div class="screen-hero__scrim" aria-hidden="true"></div>
                <div class="screen-hero__content">
                  <a class="screen-hero__cta" href="/#practice">
                    <span class="screen-hero__kicker">Practice area</span>
                    <h2 class="screen-hero__title">Business law</h2>
                    <span class="screen-hero__arrow" aria-hidden="true">→</span>
                  </a>
                </div>
              </article>
            </div>
            <div
              class="screen-hero__dots"
              role="tablist"
              aria-label="Choose slide"
            >
              <button
                type="button"
                class="screen-hero__dot is-active"
                role="tab"
                aria-selected="true"
                aria-controls="carousel-slide-0"
                data-carousel-dot="0"
              >
                <span class="visually-hidden">Firm logo and estate planning</span>
              </button>
              <button
                type="button"
                class="screen-hero__dot"
                role="tab"
                aria-selected="false"
                aria-controls="carousel-slide-1"
                data-carousel-dot="1"
              >
                <span class="visually-hidden">Probate and trust</span>
              </button>
              <button
                type="button"
                class="screen-hero__dot"
                role="tab"
                aria-selected="false"
                aria-controls="carousel-slide-2"
                data-carousel-dot="2"
              >
                <span class="visually-hidden">Business law</span>
              </button>
            </div>
          </div>
          <p class="screen-hero__hint" aria-hidden="true">Scroll</p>
        </section>
        {.end}

        {squarespace.main-content}
      </main>

      <footer class="site-footer">
        <div class="site-footer__bg" aria-hidden="true"></div>
        <div class="site-footer__inner">
          <div class="site-footer__brand">
            {.section website}
              {.if logoImageUrl}
                <img
                  class="site-footer__logo"
                  src="{logoImageUrl}"
                  width="120"
                  height="56"
                  alt=""
                />
              {.end}
              <p class="site-footer__tagline">Estate · Probate · Business</p>
            {.end}
          </div>
          <div class="site-footer__blocks">
            <squarespace:block-field id="footerBlocks" columns="12" />
          </div>
        </div>
        <p class="site-footer__meta">
          &copy; {.section website}{siteTitle}{.end}
        </p>
      </footer>
    </div>

    <squarespace:script src="site.js" combo="{.if authenticatedAccount}false{.or}true{.end}" />
    {squarespace-footers}
  </body>
</html>
