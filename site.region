<!doctype html>
<html lang="en">
  <head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no">
    <meta name="color-scheme" content="light">
    <meta name="theme-color" content="#1a3d30">
    {squarespace-headers}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400&amp;family=Source+Sans+Pro:ital,wght@0,400;0,500;0,600;0,700;1,400&amp;display=swap" rel="stylesheet">
  </head>
  <body id="{squarespace.page-id}" class="{squarespace.page-classes}">
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="app">
      <header class="app-bar">
        <div class="app-bar__toolbar md-elevation-app-bar">
          {.section website}
            <a class="app-bar__brand" href="/">
              {.if logoImageUrl}
                <img class="app-bar__logo" src="{logoImageUrl}" width="160" height="74" alt="">
              {.or}
                <img class="app-bar__logo" src="assets/kingsbery-johnson/KJL-logo.png" width="160" height="74" alt="">
              {.end}
              <span class="app-bar__title">{siteTitle}</span>
            </a>
          {.end}
          <button
            type="button"
            class="app-bar__icon-btn"
            aria-expanded="false"
            aria-controls="primary-nav"
            aria-label="Open menu"
          >
            <span class="app-bar__icon-btn-inner" aria-hidden="true">
              <span class="app-bar__menu-line"></span>
              <span class="app-bar__menu-line"></span>
              <span class="app-bar__menu-line"></span>
            </span>
          </button>
          <nav class="app-bar__nav" id="primary-nav" aria-label="Primary">
            <ul class="app-bar__list">
              <li class="app-bar__item app-bar__item--has-sub">
                <a class="app-bar__link" href="/who">Who we are</a>
                <ul class="app-bar__sub" aria-label="Attorneys">
                  <li><a href="/love">Eric V. Love</a></li>
                  <li><a href="/lehman">Jonathan A. Lehmann</a></li>
                  <li><a href="/boyd">Abby C. Boyd</a></li>
                  <li><a href="/kingsber">Walter W. Kingsbery</a></li>
                </ul>
              </li>
              <li class="app-bar__item">
                <a class="app-bar__link" href="/#practice">What we do</a>
              </li>
              <li class="app-bar__item">
                <a class="app-bar__link" href="/contact">Contact</a>
              </li>
            </ul>
          </nav>
        </div>
        <div class="app-bar__scrim" aria-hidden="true"></div>
      </header>

      <main id="main" class="content-container" role="main" data-content-field="main-content">
        <section
          class="screen-hero"
          data-home-section
          aria-label="Practice highlights"
          data-carousel
          aria-roledescription="carousel"
        >
          <div class="screen-hero__media">
            <div class="screen-hero__slides">
              <article
                id="carousel-slide-0"
                class="screen-hero__slide screen-hero__slide--lead is-active"
                data-slide="0"
                aria-hidden="false"
              >
                <img
                  class="screen-hero__img"
                  src="assets/kingsbery-johnson/estate-planning-orbit.jpg"
                  alt=""
                  width="1200"
                  height="800"
                  fetchpriority="high"
                  decoding="async"
                />
                <div class="screen-hero__scrim" aria-hidden="true"></div>
                <div class="screen-hero__content screen-hero__content--lead">
                  <div class="screen-hero__brand-badge">
                    <img
                      class="screen-hero__brand-logo"
                      src="assets/kingsbery-johnson/KJL-logo.png"
                      width="560"
                      height="258"
                      alt=""
                    />
                    <p class="screen-hero__firm-subhead">
                      {.section website}{siteTitle}{.end}
                    </p>
                  </div>
                  <a class="screen-hero__cta" href="/#practice">
                    <h2 class="screen-hero__title">Estate planning</h2>
                    <span class="screen-hero__arrow" aria-hidden="true">→</span>
                  </a>
                </div>
              </article>
              <article
                id="carousel-slide-1"
                class="screen-hero__slide"
                data-slide="1"
                aria-hidden="true"
              >
                <img
                  class="screen-hero__img"
                  src="assets/kingsbery-johnson/estate-probate-trust-orbit.jpg"
                  alt=""
                  width="1200"
                  height="800"
                  decoding="async"
                />
                <div class="screen-hero__scrim" aria-hidden="true"></div>
                <div class="screen-hero__content">
                  <a class="screen-hero__cta" href="/#practice">
                    <h2 class="screen-hero__title">Probate &amp; trust administration</h2>
                    <span class="screen-hero__arrow" aria-hidden="true">→</span>
                  </a>
                </div>
              </article>
              <article
                id="carousel-slide-2"
                class="screen-hero__slide"
                data-slide="2"
                aria-hidden="true"
              >
                <img
                  class="screen-hero__img"
                  src="assets/kingsbery-johnson/business-orbit.jpg"
                  alt=""
                  width="1200"
                  height="800"
                  decoding="async"
                />
                <div class="screen-hero__scrim" aria-hidden="true"></div>
                <div class="screen-hero__content">
                  <a class="screen-hero__cta" href="/#practice">
                    <h2 class="screen-hero__title">Business law</h2>
                    <span class="screen-hero__arrow" aria-hidden="true">→</span>
                  </a>
                </div>
              </article>
            </div>
            <div
              class="screen-hero__dots"
              role="tablist"
              aria-label="Choose slide"
            >
              <button
                type="button"
                class="screen-hero__dot is-active"
                role="tab"
                aria-selected="true"
                aria-controls="carousel-slide-0"
                data-carousel-dot="0"
              >
                <span class="visually-hidden">Firm logo and estate planning</span>
              </button>
              <button
                type="button"
                class="screen-hero__dot"
                role="tab"
                aria-selected="false"
                aria-controls="carousel-slide-1"
                data-carousel-dot="1"
              >
                <span class="visually-hidden">Probate and trust</span>
              </button>
              <button
                type="button"
                class="screen-hero__dot"
                role="tab"
                aria-selected="false"
                aria-controls="carousel-slide-2"
                data-carousel-dot="2"
              >
                <span class="visually-hidden">Business law</span>
              </button>
            </div>
          </div>
          <p class="screen-hero__hint" aria-hidden="true">Scroll</p>
        </section>

        <section
          id="practice"
          class="practice-strip"
          data-home-section
          aria-labelledby="practice-strip-heading"
        >
          <div class="practice-strip__inner">
            <h2 id="practice-strip-heading" class="practice-strip__title">
              What we do
            </h2>
            <ul class="practice-strip__list">
              <li><a class="practice-strip__link" href="/#practice">Estate planning</a></li>
              <li><a class="practice-strip__link" href="/#practice">Probate &amp; trust administration</a></li>
              <li><a class="practice-strip__link" href="/#practice">Business law</a></li>
            </ul>
          </div>
        </section>

        <section class="about" id="who-we-are" data-home-section aria-labelledby="about-heading">
          <div class="about__inner">
            <div class="about__intro">
              <p class="about__eyebrow">Since 1982 · Colorado</p>
              <h2 id="about-heading" class="about__title">
                Counsel rooted in clarity and care.
              </h2>
              <div class="about__copy">
                <p>
                  Kingsbery, Johnson &amp; Love, LLP is a boutique firm serving clients statewide:
                  estate and business planning, trust and estate administration, and steady
                  guidance for families and owners.
                </p>
                <p>
                  We tailor advice to your situation and keep communication prompt and plain-spoken.
                </p>
              </div>
            </div>
            <div class="about__expect">
              <h3 class="about__expect-heading">What to expect</h3>
              <ul class="about__expect-list">
                <li class="about__expect-item">
                  <span class="about__expect-icon" aria-hidden="true"></span>
                  <span>A clear plan and defined process</span>
                </li>
                <li class="about__expect-item">
                  <span class="about__expect-icon" aria-hidden="true"></span>
                  <span>Emails and calls returned promptly</span>
                </li>
                <li class="about__expect-item">
                  <span class="about__expect-icon" aria-hidden="true"></span>
                  <span>Professional, expert staff</span>
                </li>
                <li class="about__expect-item">
                  <span class="about__expect-icon" aria-hidden="true"></span>
                  <span>Collaboration with your advisors</span>
                </li>
              </ul>
            </div>
          </div>
          <div class="about__team" aria-labelledby="about-team-heading">
            <h3 id="about-team-heading" class="about__team-heading">
              Our attorneys
            </h3>
            <ul class="about__team-list">
              <li>
                <a class="about__team-link" href="/love">
                  <img class="about__team-photo" src="assets/attorneys/eric-love.jpg" alt="Eric V. Love" width="400" height="600" loading="lazy" decoding="async">
                  <span class="about__team-name">Eric V. Love</span>
                </a>
              </li>
              <li>
                <a class="about__team-link" href="/lehman">
                  <img class="about__team-photo" src="assets/attorneys/jonathan-lehmann.jpg" alt="Jonathan A. Lehmann" width="400" height="600" loading="lazy" decoding="async">
                  <span class="about__team-name">Jonathan A. Lehmann</span>
                </a>
              </li>
              <li>
                <a class="about__team-link" href="/boyd">
                  <img class="about__team-photo" src="assets/attorneys/abby-boyd.jpg" alt="Abby C. Boyd" width="400" height="600" loading="lazy" decoding="async">
                  <span class="about__team-name">Abby C. Boyd</span>
                </a>
              </li>
              <li>
                <a class="about__team-link" href="/kingsber">
                  <img class="about__team-photo" src="assets/attorneys/walter-kingsbery.jpg" alt="Walter W. Kingsbery" width="400" height="600" loading="lazy" decoding="async">
                  <span class="about__team-name">Walter W. Kingsbery</span>
                </a>
              </li>
            </ul>
            <p class="about__team-more">
              <a href="/who">Meet the team</a>
            </p>
          </div>
        </section>

        <section class="page-profile" data-who-section hidden>
          <div class="page-sheet">
            <nav class="profile__breadcrumb" aria-label="Breadcrumb">
              <a href="/">Home</a>
              · Who we are
            </nav>
            <h1 class="page-sheet__title">Who we are</h1>
            <p class="page-sheet__lead">
              Kingsbery, Johnson &amp; Love, LLP, is a boutique law firm located in Lafayette,
              Colorado. Our practice is focused on estate, wealth transfer, and tax planning
              services, as well as estate and trust administration. The firm was founded in
              1982 and serves Boulder County, the Denver metro area, and surrounding communities
              throughout Colorado.
            </p>
            <p>
              <img
                src="assets/kingsbery-johnson/atty-group.jpg"
                alt="Kingsbery, Johnson &amp; Love attorneys group photo"
                width="600"
                height="400"
                loading="lazy"
                decoding="async"
              >
            </p>
            <h2 class="page-sheet__title">Our attorneys</h2>
            <ul class="team-grid">
              <li>
                <a class="team-card" href="/love">
                  <img class="team-card__photo" src="assets/attorneys/eric-love.jpg" alt="Eric V. Love" width="400" height="600" loading="lazy" decoding="async">
                  <span class="team-card__name">Eric V. Love</span>
                  <span class="team-card__role">Partner · Estate &amp; trust</span>
                </a>
              </li>
              <li>
                <a class="team-card" href="/lehman">
                  <img class="team-card__photo" src="assets/attorneys/jonathan-lehmann.jpg" alt="Jonathan A. Lehmann" width="400" height="600" loading="lazy" decoding="async">
                  <span class="team-card__name">Jonathan A. Lehmann</span>
                  <span class="team-card__role">Partner · Planning &amp; business</span>
                </a>
              </li>
              <li>
                <a class="team-card" href="/boyd">
                  <img class="team-card__photo" src="assets/attorneys/abby-boyd.jpg" alt="Abby C. Boyd" width="400" height="600" loading="lazy" decoding="async">
                  <span class="team-card__name">Abby C. Boyd</span>
                  <span class="team-card__role">Partner · Planning &amp; probate</span>
                </a>
              </li>
              <li>
                <a class="team-card" href="/kingsber">
                  <img class="team-card__photo" src="assets/attorneys/walter-kingsbery.jpg" alt="Walter W. Kingsbery" width="400" height="600" loading="lazy" decoding="async">
                  <span class="team-card__name">Walter W. Kingsbery</span>
                  <span class="team-card__role">Founding partner</span>
                </a>
              </li>
            </ul>
            <h2 class="page-sheet__title">Our attorneys have represented clients in:</h2>
            <ul class="page-sheet__list">
              <li>
                Estate and tax planning for high-net worth clients with complex assets including
                real estate investments and private equity interests, international assets and
                complex trusts;
              </li>
              <li>
                Estate, probate and trust administration involving seven figure estate tax liability
                and assessing tax consequences of complex trusts;
              </li>
              <li>
                Adversarial probate and trust proceedings involving disputes among beneficiaries as
                well as representing fiduciaries during administration of an estate;
              </li>
              <li>Expert testimony regarding trusts in a divorce context;</li>
              <li>
                Working with entrepreneurs on establishing businesses, choice of entity, partnership
                agreements and buy-sell agreements;
              </li>
              <li>
                Advising family owned and closely-held companies on succession and tax planning;
              </li>
              <li>Representing clients during marital agreement negotiations;</li>
              <li>Advising executives on consulting contracts and liability concerns.</li>
            </ul>
          </div>
        </section>

        <section class="page-profile" data-profile-section="love" hidden>
          <article class="profile">
            <nav class="profile__breadcrumb" aria-label="Breadcrumb">
              <a href="/">Home</a> · <a href="/who">Who we are</a> · Eric V. Love
            </nav>
            <header class="profile__hero">
              <div class="profile__intro">
                <div class="profile__photo-frame">
                  <img class="profile__photo-img" src="assets/attorneys/eric-love.jpg" alt="Eric V. Love Portrait" width="400" height="600" loading="lazy" decoding="async">
                </div>
                <div>
                  <p class="profile__role">Partner · Estate &amp; trust</p>
                  <h1 class="profile__name">Eric V. Love</h1>
                </div>
              </div>
            </header>
            <div class="profile__body">
              <section class="profile__section">
                <h2>Overview</h2>
                <p>
                  Eric V. Love is the managing partner of the firm. His practice focuses on
                  estate planning, estate and trust administration and estate and gift tax matters.
                </p>
                <p>
                  Eric received his undergraduate degree in business administration and accounting
                  from the University of Kansas. He is also a CPA and worked for Deloitte &amp; Touche
                  as an auditor. Eric received his law degree from the University of Kansas before joining
                  the firm in 1994. He has served on the boards of directors of the Colorado Music Festival,
                  Downtown Boulder, Inc., Imagine!, and the Board of Trustees of the Boulder Community
                  Hospital Foundation. Eric is listed in the Best Lawyers of America 2017 Trusts and Estates.
                  He is AV Pre-Eminent rated by Martindale Hubbell. Eric lives in Erie with his wife Jennifer
                  and son Joshua.
                </p>
              </section>
              <section class="profile__section">
                <h2>Practice areas</h2>
                <ul>
                  <li>Estate planning and wills</li>
                  <li>Revocable and irrevocable trusts</li>
                  <li>Probate and trust administration</li>
                  <li>Tax-sensitive wealth transfer strategies</li>
                </ul>
              </section>
            </div>
            <nav class="profile__siblings" aria-label="Our attorneys">
              <h2 class="profile__siblings-title">Our attorneys</h2>
              <ul class="profile__siblings-list">
                <li><a href="/love" aria-current="page">Eric V. Love</a></li>
                <li><a href="/lehman">Jonathan A. Lehmann</a></li>
                <li><a href="/boyd">Abby C. Boyd</a></li>
                <li><a href="/kingsber">Walter W. Kingsbery</a></li>
              </ul>
            </nav>
          </article>
        </section>

        <section class="page-profile" data-profile-section="lehman" hidden>
          <article class="profile">
            <nav class="profile__breadcrumb" aria-label="Breadcrumb">
              <a href="/">Home</a> · <a href="/who">Who we are</a> · Jonathan A. Lehmann
            </nav>
            <header class="profile__hero">
              <div class="profile__intro">
                <div class="profile__photo-frame">
                  <img class="profile__photo-img" src="assets/attorneys/jonathan-lehmann.jpg" alt="Jonathan A. Lehmann Portrait" width="400" height="600" loading="lazy" decoding="async">
                </div>
                <div>
                  <p class="profile__role">Partner · Planning &amp; business</p>
                  <h1 class="profile__name">Jonathan A. Lehmann</h1>
                </div>
              </div>
            </header>
            <div class="profile__body">
              <section class="profile__section">
                <h2>Overview</h2>
                <p>
                  Jonathan A. Lehmann is a partner with the firm. His practice focuses on
                  estate and tax planning; probate, estate and trust administration; advising
                  family and closely-held businesses; and counseling executives and entrepreneurs.
                </p>
                <p>
                  Jonathan is originally from Minnesota. He received his undergraduate degree
                  from Wisconsin in 2000 (magna cum laude) and his law degree from Florida State
                  University School of Law in 2005 (cum laude). While at Florida State, he served
                  as a tax research assistant and was a member of the Journal of Transnational Law
                  &amp; Policy and Journal of Land Use &amp; Environmental Law. Jonathan has presented
                  at various seminars covering topics such as charitable planning and giving, succession
                  planning, the pitfalls of serving as a trustee and considerations for buy-sell
                  agreements. Jonathan is a member of the American, Colorado, Denver and Boulder County
                  Bar associations. He is also admitted to the Federal Court of Claims. In his spare
                  time, Jonathan is a member of Social Venture Partners of Boulder County and a founder
                  of the Boulder Business Leaders Group. He lives in Lafayette with his wife Shawna and
                  his two sons, Graham and Owen.
                </p>
              </section>
              <section class="profile__section">
                <h2>Practice areas</h2>
                <ul>
                  <li>Estate and gift planning</li>
                  <li>Business formation and governance</li>
                  <li>Contracts and transactions</li>
                  <li>Trust administration</li>
                </ul>
              </section>
            </div>
            <nav class="profile__siblings" aria-label="Our attorneys">
              <h2 class="profile__siblings-title">Our attorneys</h2>
              <ul class="profile__siblings-list">
                <li><a href="/love">Eric V. Love</a></li>
                <li><a href="/lehman" aria-current="page">Jonathan A. Lehmann</a></li>
                <li><a href="/boyd">Abby C. Boyd</a></li>
                <li><a href="/kingsber">Walter W. Kingsbery</a></li>
              </ul>
            </nav>
          </article>
        </section>

        <section class="page-profile" data-profile-section="boyd" hidden>
          <article class="profile">
            <nav class="profile__breadcrumb" aria-label="Breadcrumb">
              <a href="/">Home</a> · <a href="/who">Who we are</a> · Abby C. Boyd
            </nav>
            <header class="profile__hero">
              <div class="profile__intro">
                <div class="profile__photo-frame">
                  <img class="profile__photo-img" src="assets/attorneys/abby-boyd.jpg" alt="Abby C. Boyd Portrait" width="400" height="600" loading="lazy" decoding="async">
                </div>
                <div>
                  <p class="profile__role">Partner · Planning &amp; probate</p>
                  <h1 class="profile__name">Abby C. Boyd</h1>
                </div>
              </div>
            </header>
            <div class="profile__body">
              <section class="profile__section">
                <h2>Overview</h2>
                <p>
                  Abby C. Boyd is a partner with the firm. Her practice focuses on estate and tax
                  planning and estate and trust administration. Originally from Maryland, she has
                  lived in Colorado since 2014.
                </p>
                <p>
                  She received her undergraduate degree from the University of Maryland, Baltimore
                  County (UMBC) and a master's degree in teaching from Towson University. Prior to
                  attending law school, she was a high school social studies teacher. She graduated
                  from the University of Baltimore School of Law (summa cum laude) and was awarded
                  entry into the Heuisler Honor Society. Before joining the firm, Abby was a law clerk
                  for the Honorable Edward D. Bronfin in Denver District Court. She is a former chair
                  of the City of Lafayette's Human Rights Commission and has previously served as Chair
                  of the Tax, Estate Planning, and Probate Section of the Boulder County Bar Association.
                  She is a member of the Colorado, Colorado Women's, and Boulder County bar associations.
                  Abby lives in Lafayette, and enjoys reading, hiking, and cooking.
                </p>
              </section>
              <section class="profile__section">
                <h2>Practice areas</h2>
                <ul>
                  <li>Wills and powers of attorney</li>
                  <li>Special needs and supplemental planning</li>
                  <li>Probate administration</li>
                  <li>Trust modification and distribution</li>
                </ul>
              </section>
            </div>
            <nav class="profile__siblings" aria-label="Our attorneys">
              <h2 class="profile__siblings-title">Our attorneys</h2>
              <ul class="profile__siblings-list">
                <li><a href="/love">Eric V. Love</a></li>
                <li><a href="/lehman">Jonathan A. Lehmann</a></li>
                <li><a href="/boyd" aria-current="page">Abby C. Boyd</a></li>
                <li><a href="/kingsber">Walter W. Kingsbery</a></li>
              </ul>
            </nav>
          </article>
        </section>

        <section class="page-profile" data-profile-section="kingsber" hidden>
          <article class="profile">
            <nav class="profile__breadcrumb" aria-label="Breadcrumb">
              <a href="/">Home</a> · <a href="/who">Who we are</a> · Walter W. Kingsbery
            </nav>
            <header class="profile__hero">
              <div class="profile__intro">
                <div class="profile__photo-frame">
                  <img class="profile__photo-img" src="assets/attorneys/walter-kingsbery.jpg" alt="Walter W. Kingsbery Portrait" width="400" height="600" loading="lazy" decoding="async">
                </div>
                <div>
                  <p class="profile__role">Of counsel · Estate planning</p>
                  <h1 class="profile__name">Walter W. Kingsbery</h1>
                </div>
              </div>
            </header>
            <div class="profile__body">
              <section class="profile__section">
                <h2>Overview</h2>
                <p>
                  Walter W. Kingsbery is "mostly" retired, but remains of counsel to the firm.
                  He received his undergraduate degree in accounting from Texas A&amp;M in 1975,
                  and his law degree from Harvard University in 1979.
                </p>
                <p>
                  His practice focuses on estate planning, estate and trust administration and tax-exempt
                  organizations. Walter is currently on the board of directors of Live by Living Foundation,
                  and has served on the boards of the International Mountain Explorers Connection, Imagine!
                  and Global Response. He spends his free time on a wide spectrum of outdoor activities,
                  reading, relaxing and socializing.
                </p>
              </section>
              <section class="profile__section">
                <h2>Practice areas</h2>
                <ul>
                  <li>Comprehensive estate planning</li>
                  <li>Business succession</li>
                  <li>Trust and estate administration</li>
                  <li>Tax planning coordination</li>
                </ul>
              </section>
            </div>
            <nav class="profile__siblings" aria-label="Our attorneys">
              <h2 class="profile__siblings-title">Our attorneys</h2>
              <ul class="profile__siblings-list">
                <li><a href="/love">Eric V. Love</a></li>
                <li><a href="/lehman">Jonathan A. Lehmann</a></li>
                <li><a href="/boyd">Abby C. Boyd</a></li>
                <li><a href="/kingsber" aria-current="page">Walter W. Kingsbery</a></li>
              </ul>
            </nav>
          </article>
        </section>

        <div class="cms-main-content" data-cms-content>
          {squarespace.main-content}
        </div>
      </main>

      <footer class="site-footer">
        <div class="site-footer__bg" aria-hidden="true"></div>
        <div class="site-footer__inner">
          <div class="site-footer__brand">
            {.section website}
              {.if logoImageUrl}
                <img
                  class="site-footer__logo"
