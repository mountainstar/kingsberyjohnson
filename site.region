<!doctype html>
<html lang="en">
  <head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no">
    <meta name="theme-color" content="#1a3d30">
    {squarespace-headers}
    <link rel="icon" type="image/svg+xml" href="assets/kingsbery-johnson/KJL-logo.svg">
    <link rel="alternate icon" type="image/png" href="assets/kingsbery-johnson/KJL-logo.png">
    <link rel="apple-touch-icon" href="assets/kingsbery-johnson/KJL-logo.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600;6..72,700&amp;family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet">
  </head>
  <body id="{squarespace.page-id}" class="{squarespace.page-classes} wa-body">
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="app">
      <header class="wa-header">
        <div class="wa-container wa-header__inner">
          {.section website}
            <a class="wa-brand" href="/">
              <img class="wa-brand__logo" src="assets/kingsbery-johnson/KJL-logo.png" width="120" height="56" alt="">
              <span>{siteTitle}</span>
            </a>
          {.end}
          <button class="wa-menu-btn" type="button" aria-expanded="false" aria-controls="wa-nav" aria-label="Open menu">Menu</button>
          <nav class="wa-nav" id="wa-nav" aria-label="Primary">
            <ul class="wa-nav__list">
              <li class="wa-nav__item wa-nav__item--has-sub">
                <a href="/who">Who we are</a>
                <ul class="wa-nav__sub" aria-label="Attorneys">
                  <li><a href="/love">Eric V. Love</a></li>
                  <li><a href="/lehman">Jonathan A. Lehmann</a></li>
                  <li><a href="/boyd">Abby C. Boyd</a></li>
                  <li><a href="/kingsber">Walter W. Kingsbery</a></li>
                </ul>
              </li>
              <li class="wa-nav__item wa-nav__item--has-sub">
                <a href="/what">What we do</a>
                <ul class="wa-nav__sub" aria-label="Practice areas">
                  <li><a href="/estateplanning">Estate Planning</a></li>
                  <li><a href="/estateprobatetrust">Estate, Probate and Trust Administration</a></li>
                  <li><a href="/businesslaw">Business Law</a></li>
                </ul>
              </li>
              <li><a href="/contact">Contact</a></li>
            </ul>
          </nav>
        </div>
      </header>

      <main id="main" class="content-container" role="main" data-content-field="main-content">
        <section class="wa-hero" data-home-section>
          <div class="wa-container wa-hero__grid">
            <div>
              <p class="wa-eyebrow">Boulder • Since 1982 • Colorado</p>
              <h1>Counsel rooted in clarity and care.</h1>
              <p>Kingsbery, Johnson &amp; Love, LLP is a boutique law firm serving clients throughout Colorado.</p>
              <p>Founded in 1982, our practice is devoted to expertly guiding our clients through estate and business planning and trust and estate administration.</p>
              <div class="wa-actions">
                <a href="/what">Explore Practice Areas</a>
                <a href="/contact">Contact Our Office</a>
              </div>
            </div>
            <aside class="wa-hero__card">
              <h2>What to Expect</h2>
              <p>We tailor advice to your situation and keep communication prompt and plain-spoken.</p>
              <ul>
                <li>A clear plan and defined process</li>
                <li>Professional and expert staff</li>
                <li>Collaboration with your chosen advisors</li>
              </ul>
            </aside>
          </div>
        </section>
        <section class="wa-team" data-home-section id="team">
          <div class="wa-container">
            <div class="wa-team__head">
              <h2>Team</h2>
              <a href="/who">View detailed attorney profiles</a>
            </div>
            <ul class="wa-home-team">
              <li><a href="/love"><img class="wa-home-team__img" src="assets/attorneys/eric-love.jpg" alt="Eric V. Love" width="96" height="96"><span>Eric V. Love</span></a></li>
              <li><a href="/lehman"><img class="wa-home-team__img" src="assets/attorneys/jonathan-lehmann.jpg" alt="Jonathan A. Lehmann" width="96" height="96"><span>Jonathan A. Lehmann</span></a></li>
              <li><a href="/boyd"><img class="wa-home-team__img" src="assets/attorneys/abby-boyd.jpg" alt="Abby C. Boyd" width="96" height="96"><span>Abby C. Boyd</span></a></li>
              <li><a href="/kingsber"><img class="wa-home-team__img" src="assets/attorneys/walter-kingsbery.jpg" alt="Walter W. Kingsbery" width="96" height="96"><span>Walter W. Kingsbery</span></a></li>
            </ul>
          </div>
        </section>
        <section class="wa-practice" data-home-section id="practice-areas">
          <div class="wa-container">
            <h2>Practice Areas</h2>
            <div class="wa-grid">
              <a href="/estateplanning">Estate planning</a>
              <a href="/estateprobatetrust">Probate &amp; trust administration</a>
              <a href="/businesslaw">Business law</a>
            </div>
          </div>
        </section>
        <section class="wa-offices" data-home-section id="offices">
          <div class="wa-container wa-offices__grid">
            <article>
              <h2>Visit</h2>
              <p>2672 North Park Dr, Ste 100</p>
              <p>Lafayette, CO 80026</p>
              <p><a href="tel:+13034434694">303.443.4694</a></p>
            </article>
            <article>
              <h2>Connect</h2>
              <p><a href="/contact">Contact our office</a></p>
              <p><a href="/who">Meet the team</a></p>
              <p><a href="/what">Practice areas</a></p>
            </article>
          </div>
        </section>
        <section class="wa-advantage" data-home-section id="advantage">
          <div class="wa-container">
            <h2>Why clients choose KJL</h2>
            <div class="wa-advantage__grid">
              <article><h3>Steady Guidance</h3><p>We provide practical planning and administration counsel with clear next steps at every stage.</p></article>
              <article><h3>Prompt Communication</h3><p>Clients and advisors can expect responsive calls, emails, and coordinated support.</p></article>
              <article><h3>Integrated Perspective</h3><p>Estate planning, probate and trust administration, and business counsel work together as one strategy.</p></article>
            </div>
          </div>
        </section>

        <section class="wa-page" data-who-section hidden>
          <div class="wa-container">
            <nav class="wa-crumbs" aria-label="Breadcrumb"><a href="/">Home</a> · Who we are</nav>
            <h1 class="wa-page__title">Who we are</h1>
            <p class="wa-page__lead">Kingsbery, Johnson &amp; Love, LLP is a boutique law firm located in Lafayette, Colorado. Our practice is focused on estate, wealth transfer, and tax planning services, as well as estate and trust administration.</p>
            <section class="wa-profile__section">
              <p>The firm was founded in 1982 and serves Boulder County, the Denver metro area, and surrounding communities throughout Colorado.</p>
            </section>
            <ul class="wa-people-grid">
              <li><a class="wa-person-card" href="/love"><img class="wa-person-card__img" src="assets/attorneys/eric-love.jpg" alt="Eric V. Love"><span class="wa-person-card__name">Eric V. Love</span><span class="wa-person-card__role">Partner · Estate &amp; trust</span></a></li>
              <li><a class="wa-person-card" href="/lehman"><img class="wa-person-card__img" src="assets/attorneys/jonathan-lehmann.jpg" alt="Jonathan A. Lehmann"><span class="wa-person-card__name">Jonathan A. Lehmann</span><span class="wa-person-card__role">Partner · Planning &amp; business</span></a></li>
              <li><a class="wa-person-card" href="/boyd"><img class="wa-person-card__img" src="assets/attorneys/abby-boyd.jpg" alt="Abby C. Boyd"><span class="wa-person-card__name">Abby C. Boyd</span><span class="wa-person-card__role">Partner · Planning &amp; probate</span></a></li>
              <li><a class="wa-person-card" href="/kingsber"><img class="wa-person-card__img" src="assets/attorneys/walter-kingsbery.jpg" alt="Walter W. Kingsbery"><span class="wa-person-card__name">Walter W. Kingsbery</span><span class="wa-person-card__role">Founding partner</span></a></li>
            </ul>
          </div>
        </section>

        <section class="wa-page" data-what-section hidden>
          <div class="wa-container">
            <nav class="wa-crumbs" aria-label="Breadcrumb"><a href="/">Home</a> · What we do</nav>
            <h1 class="wa-page__title">What we do</h1>
            <p class="wa-page__lead">We advise individuals, families, trustees, personal representatives, and business owners across Colorado with practical, coordinated legal guidance.</p>
            <section class="wa-profile__section">
              <h2>Practice areas</h2>
              <div class="wa-grid">
                <a href="/estateplanning">Estate planning</a>
                <a href="/estateprobatetrust">Probate &amp; trust administration</a>
                <a href="/businesslaw">Business law</a>
              </div>
            </section>
          </div>
        </section>

        <section class="wa-page" data-practice-section="estateplanning" hidden>
          <article class="wa-container wa-profile">
            <nav class="wa-crumbs"><a href="/">Home</a> · What we do · Estate planning</nav>
            <h1 class="wa-page__title">Estate planning</h1>
            <section class="wa-profile__section"><p>We provide estate, wealth transfer, and tax planning services to individuals, couples and families.</p></section>
            <section class="wa-profile__section"><h2>Services include</h2><ul><li>Wills and revocable trusts</li><li>Powers of attorney and healthcare directives</li><li>Asset transfer and beneficiary coordination</li><li>Updates for life and tax law changes</li></ul></section>
          </article>
        </section>

        <section class="wa-page" data-practice-section="estateprobatetrust" hidden>
          <article class="wa-container wa-profile">
            <nav class="wa-crumbs"><a href="/">Home</a> · What we do · Probate &amp; trust administration</nav>
            <h1 class="wa-page__title">Probate &amp; trust administration</h1>
            <section class="wa-profile__section"><p>Our firm has extensive experience representing personal representatives, trustees, and beneficiaries in handling estate and trust administration matters.</p></section>
            <section class="wa-profile__section"><h2>Services include</h2><ul><li>Probate filings and court process support</li><li>Trust administration and fiduciary guidance</li><li>Asset inventory, notices, and distributions</li><li>Coordination with accountants and advisors</li></ul></section>
          </article>
        </section>

        <section class="wa-page" data-practice-section="businesslaw" hidden>
          <article class="wa-container wa-profile">
            <nav class="wa-crumbs"><a href="/">Home</a> · What we do · Business law</nav>
            <h1 class="wa-page__title">Business law</h1>
            <section class="wa-profile__section"><p>We often provide business law advice to our estate planning clients, including the formation and operation of family entities and succession planning for those entities.</p></section>
            <section class="wa-profile__section"><h2>Services include</h2><ul><li>Entity formation and organizational documents</li><li>Owner agreements and governance updates</li><li>Contract drafting and review</li><li>Succession planning and transition strategy</li></ul></section>
          </article>
        </section>

        <section class="wa-page" data-contact-section hidden>
          <div class="wa-container">
            <nav class="wa-crumbs"><a href="/">Home</a> · Contact</nav>
            <h1 class="wa-page__title">Contact us</h1>
            <p class="wa-page__lead">Kingsbery, Johnson &amp; Love, LLP<br>2672 North Park Drive, Suite 100<br>Lafayette, CO 80026<br>Phone: 303.443.4694<br>Fax: 303.443.1335</p>
          </div>
        </section>



        <section class="wa-page" data-profile-section="love" hidden><article class="wa-container wa-profile"><nav class="wa-crumbs"><a href="/">Home</a> · <a href="/who">Who we are</a> · Eric V. Love</nav><header class="wa-profile__hero"><img class="wa-profile__img" src="assets/attorneys/eric-love.jpg" alt="Eric V. Love"><div><p class="wa-profile__role">Partner · Estate &amp; trust</p><h1 class="wa-page__title">Eric V. Love</h1></div></header><section class="wa-profile__section"><h2>Overview</h2><p>Eric V. Love is the managing partner of the firm. His practice focuses on estate planning, estate and trust administration, and estate and gift tax matters.</p></section></article></section>

        <section class="wa-page" data-profile-section="lehman" hidden><article class="wa-container wa-profile"><nav class="wa-crumbs"><a href="/">Home</a> · <a href="/who">Who we are</a> · Jonathan A. Lehmann</nav><header class="wa-profile__hero"><img class="wa-profile__img" src="assets/attorneys/jonathan-lehmann.jpg" alt="Jonathan A. Lehmann"><div><p class="wa-profile__role">Partner · Planning &amp; business</p><h1 class="wa-page__title">Jonathan A. Lehmann</h1></div></header><section class="wa-profile__section"><h2>Overview</h2><p>Jonathan A. Lehmann is a partner with the firm. His practice focuses on estate and tax planning; probate, estate and trust administration; advising family and closely-held businesses; and counseling executives and entrepreneurs.</p></section></article></section>

        <section class="wa-page" data-profile-section="boyd" hidden><article class="wa-container wa-profile"><nav class="wa-crumbs"><a href="/">Home</a> · <a href="/who">Who we are</a> · Abby C. Boyd</nav><header class="wa-profile__hero"><img class="wa-profile__img" src="assets/attorneys/abby-boyd.jpg" alt="Abby C. Boyd"><div><p class="wa-profile__role">Partner · Planning &amp; probate</p><h1 class="wa-page__title">Abby C. Boyd</h1></div></header><section class="wa-profile__section"><h2>Overview</h2><p>Abby C. Boyd is a partner with the firm. Her practice focuses on estate and tax planning and estate and trust administration.</p></section></article></section>

        <section class="wa-page" data-profile-section="kingsber" hidden><article class="wa-container wa-profile"><nav class="wa-crumbs"><a href="/">Home</a> · <a href="/who">Who we are</a> · Walter W. Kingsbery</nav><header class="wa-profile__hero"><img class="wa-profile__img" src="assets/attorneys/walter-kingsbery.jpg" alt="Walter W. Kingsbery"><div><p class="wa-profile__role">Founding partner · Planning &amp; business</p><h1 class="wa-page__title">Walter W. Kingsbery</h1></div></header><section class="wa-profile__section"><h2>Overview</h2><p>Walter has advised Colorado clients on estate planning, closely held business matters, and fiduciary administration for decades.</p></section></article></section>

        <div class="cms-main-content" data-cms-content>
          {squarespace.main-content}
        </div>
      </main>

      <footer class="wa-footer">
        <div class="wa-container wa-footer__grid">
          <div>
            <p class="wa-footer__title">{.section website}{siteTitle}{.end}</p>
            <p>Estate · Probate · Business</p>
          </div>
          <nav aria-label="Footer">
            <a href="/">Home</a>
            <a href="/who">Who we are</a>
            <a href="/what">What we do</a>
            <a href="/contact">Contact</a>
          </nav>
          <div>
            <img class="wa-footer__logo" src="assets/kingsbery-johnson/KJL-logo.png" width="120" height="56" alt="">
            <p class="wa-legal">&copy; {.section website}{siteTitle}{.end}</p>
          </div>
        </div>
      </footer>
    </div>

    <squarespace:script src="site.js" combo="{.if authenticatedAccount}false{.or}true{.end}" />
    {squarespace-footers}
  </body>
</html>
